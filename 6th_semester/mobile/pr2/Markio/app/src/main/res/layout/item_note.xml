<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_note_card"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Title Row with Edit/Delete icons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvNoteTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Заголовок"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnEditNote"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit"
            android:contentDescription="Редактировать"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btnDeleteNote"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            android:contentDescription="Удалить"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Note Text -->
    <TextView
        android:id="@+id/tvNoteText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Тест"
        android:textSize="14sp"
        android:textColor="@color/dark_gray"
        android:layout_marginBottom="6dp" />

    <!-- Note Date -->
    <TextView
        android:id="@+id/tvNoteDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="22 февраля 2026"
        android:textSize="12sp"
        android:textColor="@color/medium_gray" />

</LinearLayout>
